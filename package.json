    "commander": "^12.1.0",
    "crypto-js": "^4.2.0",
    "express": "^4.22.2"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
